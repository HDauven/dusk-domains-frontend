# Dusk Domains runtime configuration.
# Copy to .env.local for local Vite development, then replace placeholders with deployed values.

# Required for live-ready core-stack mode. Each contract ID must be 0x plus 64 hex characters.
VITE_DUSK_DOMAINS_CORE_CONTRACT_ID=
VITE_DUSK_DOMAINS_TREASURY_CONTRACT_ID=

# Required for live-ready mode. Use a root-relative path or an http(s) URL.
VITE_DUSK_DOMAINS_INDEXER_URL=

# Dusk Connect / node settings for live contract reads and writes.
VITE_DUSK_DOMAINS_NODE_URL=https://testnet.nodes.dusk.network
VITE_DUSK_DOMAINS_CHAIN_ID=dusk:2

# Keep disabled until contract IDs and data-driver artifacts are deployed and reviewed.
VITE_DUSK_DOMAINS_ENABLE_LIVE_WRITES=false

# Optional launch/support links. Configure before public beta; unset links are hidden.
VITE_DUSK_DOMAINS_SUPPORT_URL=
VITE_DUSK_DOMAINS_ABUSE_URL=
VITE_DUSK_DOMAINS_SECURITY_URL=
VITE_DUSK_DOMAINS_STATUS_URL=

# Optional Vite-dev-only wallet shim for browser connection/state testing.
# This provider cannot submit real transactions unless a trusted local write bridge is configured.
VITE_DUSK_DOMAINS_ENABLE_LOCAL_DEV_WALLET=false
VITE_DUSK_DOMAINS_LOCAL_DEV_ACCOUNT=dusk1qz9p7m3ct4un8k6ry4l0vx2wjs5h9t7pa2f3c
VITE_DUSK_DOMAINS_LOCAL_DEV_WRITE_BRIDGE_URL=

# Optional data-driver WASM artifact URLs. Defaults shown here match the core-stack static app paths.
VITE_DUSK_DOMAINS_CORE_DRIVER_URL=/contracts/dusk-names-core.data-driver.wasm
VITE_DUSK_DOMAINS_TREASURY_DRIVER_URL=/contracts/dusk-name-treasury.data-driver.wasm
