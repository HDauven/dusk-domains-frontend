# Dusk Domains public beta runtime handoff.
# Copy these values into the hosted beta environment after deployment.
# Do not commit filled values, seed phrases, private keys, wallet backups, or operator credentials.

# Devnet/testnet target. Keep this aligned with the deployed contracts and proof artifacts.
VITE_DUSK_DOMAINS_NODE_URL=<devnet-or-testnet-node-url>
VITE_DUSK_DOMAINS_CHAIN_ID=dusk:3

# Deployed two-contract public MVP stack.
VITE_DUSK_DOMAINS_CORE_CONTRACT_ID=<0x-core-contract-id>
VITE_DUSK_DOMAINS_TREASURY_CONTRACT_ID=<0x-treasury-contract-id>

# Hosted data-driver WASM artifacts for the exact deployed contracts.
VITE_DUSK_DOMAINS_CORE_DRIVER_URL=<core-data-driver-url>
VITE_DUSK_DOMAINS_TREASURY_DRIVER_URL=<treasury-data-driver-url>

# Hosted production indexer API. The indexer is a derived read model; contract state remains canonical.
VITE_DUSK_DOMAINS_INDEXER_URL=<hosted-indexer-url>

# Public beta writes and optional product surfaces.
VITE_DUSK_DOMAINS_ENABLE_LIVE_WRITES=true
VITE_DUSK_DOMAINS_ENABLE_REFERRAL_ATTRIBUTION=true
VITE_DUSK_DOMAINS_ENABLE_REFERRAL_CLAIMS=true

# Public support paths. Use HTTPS, mailto:, or root-relative URLs.
VITE_DUSK_DOMAINS_SUPPORT_URL=<support-url>
VITE_DUSK_DOMAINS_ABUSE_URL=<abuse-report-url>
VITE_DUSK_DOMAINS_SECURITY_URL=<security-contact-url>
VITE_DUSK_DOMAINS_STATUS_URL=<status-url>
